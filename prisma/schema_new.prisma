generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  url      = env("DATABASE_URL")
  provider = "postgresql"
}

datasource db {
  url      = env("DATABASE_URL")
  provider = "postgresql"

model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])

model PasswordResetToken {
  id      String   @id
  email   String   @db.VarChar(255)
  token   String   @unique
  expires DateTime

  @@index([email])
  @@index([expires])
  @@index([email, expires])

model VerificationToken {
  id         String   @id
  identifier String
  token      String
  expires    DateTime
  email      String?  @db.VarChar(255)

  @@unique([token, email])

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  userId                String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @default(now())
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@map("account")
  @@index([userId])

model Address {
  id           String   @id @default(cuid())
  userId       String
  addressLine1 String?
  addressLine2 String?
  city         String?  @db.VarChar(100)
  state        String?  @db.VarChar(100)
  postalCode   String?  @db.VarChar(10)
  telephone    String?  @db.VarChar(11)
  mobile       String?  @db.VarChar(11)
  location     String?  @db.VarChar(64)
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@index([userId, isDefault])
  @@map("address")

model CartItem {
  id               String    @id
  sessionId        String?
  productId        String
  productOptionsId String?
  quantity         Int
  createdAt        DateTime? @default(now())
  modifiedAt       DateTime?
  userId           String?
  product          Product   @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  session          Session?  @relation(fields: [sessionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  user             User?     @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId])
  @@index([sessionId])
  @@index([productId])
  @@index([userId, createdAt])
  @@map("cart_item")

model Category {
  id         String    @id
  parentId   String?
  level      Int?      @db.SmallInt
  name       String?   @db.VarChar(255)
  createdAt  DateTime  @default(now())
  modifiedAt DateTime
  products   Product[]

  @@index([parentId])
  @@index([level])
  @@index([name])
  @@map("category")

model Discount {
  id          String    @id
  code        String?   @db.VarChar(255)
  description String?
  active      Boolean   @default(true)
  multiple    Boolean   @default(false)
  price       Decimal?  @db.Decimal
  percent     Decimal?  @db.Decimal
  type        String?   @db.VarChar(255)
  startDate   DateTime? @db.Timestamptz(6)
  endDate     DateTime? @db.Timestamptz(6)
  createdAt   DateTime  @default(now())
  modifiedAt  DateTime

  @@map("discount")

model OptionGroup {
  id             String          @id
  name           String?         @db.VarChar(255)
  type           String?         @db.VarChar(255)
  options        Option[]
  productOptions ProductOption[]

  @@map("option_group")

model Option {
  id             String          @id
  name           String?         @db.VarChar(255)
  value          String?         @db.VarChar(255)
  optionGroupId  String
  optionGroup    OptionGroup     @relation(fields: [optionGroupId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  productOptions ProductOption[]

  @@map("options")

model Order {
  id          String      @id
  userId      String?
  sessionId   String?
  total       Decimal     @db.Decimal
  status      String      @default("pending") @db.VarChar(50)
  deliverDate DateTime?   @db.Timestamptz(6)
  discountId  String?
  paymentId   String?
  createdAt   DateTime    @default(now())
  modifiedAt  DateTime
  session     Session?    @relation(fields: [sessionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  user        User?       @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  orderItems  OrderItem[]
  payment     Payment[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@map("order")

model OrderItem {
  id         String   @id
  orderId    String
  productId  String
  quantity   Int
  createdAt  DateTime @default(now())
  modifiedAt DateTime
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("order_items")

model Payment {
  id              String   @id
  userId          String?
  orderId         String
  amount          Decimal  @db.Decimal
  provider        String?  @db.VarChar(255)
  status          String   @db.VarChar(255)
  transactionCode String?  @db.VarChar(255)
  bankReference   String?  @db.VarChar(255)
  describe        String?
  createdAt       DateTime @default(now())
  modifiedAt      DateTime
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  user            User?    @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("payment")

model Picture {
  id              String           @id
  url             String
  type            String?          @db.VarChar(50)
  createdAt       DateTime         @default(now())
  modifiedAt      DateTime
  productPictures ProductPicture[]

  @@map("picture")

model Product {
  id              String           @id
  name            String?          @db.VarChar(255)
  desc            String?
  slug            String?          @db.VarChar(255)
  categoryId      String
  quantity        Int              @default(0)
  price           Decimal          @db.Decimal
  status          Int?             @default(1)
  discountPrice   Decimal?         @db.Decimal
  createdAt       DateTime         @default(now())
  modifiedAt      DateTime         @updatedAt
  seoTitle        String?          @db.VarChar(255)
  seoDescription  String?          @db.Text
  seoKeywords     String?          @db.Text
  ogImage         String?
  canonicalUrl    String?
  category        Category         @relation(fields: [categoryId], references: [id])
  cartItems       CartItem[]
  orderItems      OrderItem[]
  productOptions  ProductOption[]
  productPictures ProductPicture[]
  reviews         Review[]
  wishlists       Wishlist[]
  recentlyVieweds RecentlyViewed[]
  collectionProducts CollectionProduct[]

  @@unique([slug])
  @@index([categoryId])
  @@index([status])
  @@index([quantity])
  @@index([price])
  @@index([createdAt])
  @@index([name])
  @@index([slug])
  @@index([categoryId, status])
  @@index([categoryId, price])
  @@index([status, createdAt])
  @@map("product")

model ProductOption {
  id             String       @id
  optionsId      String
  productId      String
  optionGroupId  String?
  priceIncrement Decimal?     @db.Decimal
  quantity       Int          @default(0)
  optionGroup    OptionGroup? @relation(fields: [optionGroupId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  options        Option       @relation(fields: [optionsId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  product        Product      @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("product_options")

model ProductPicture {
  pictureId    String
  productId    String
  displayOrder Int     @default(0) @db.SmallInt
  id           String  @id
  picture      Picture @relation(fields: [pictureId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  product      Product @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("product_pictures")

model Review {
  id        String   @id @default(cuid())
  productId String
  userId    String
  rating    Int      @db.SmallInt
  title     String?  @db.VarChar(255)
  comment   String?
  status    String   @default("PENDING") @db.VarChar(20)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user      User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([productId])
  @@index([userId])
  @@index([rating])
  @@index([status])
  @@index([createdAt])
  @@index([productId, createdAt])
  @@index([productId, rating])
  @@index([productId, status])
  @@map("review")

model Session {
  id              String           @id
  userId          String
  token           String           @unique
  expiresAt       DateTime
  ipAddress       String?
  userAgent       String?
  impersonatedBy  String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @default(now())
  cartItems       CartItem[]
  orders          Order[]
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  recentlyVieweds RecentlyViewed[]

  @@map("session")
  @@index([userId])

model User {
  id                  String           @id
  name                String?          @db.VarChar(255)
  email               String           @unique @db.VarChar(255)
  password            String?
  role                String           @default("USER") @db.VarChar(30)
  emailVerified       Boolean?         @default(false)
  username            String?          @db.VarChar(255)
  active              Boolean?         @default(true)
  ip                  String?          @db.VarChar(50)
  image               String?
  banned              Boolean?         @default(false)
  banReason           String?
  banExpires          DateTime?
  phoneNumber         String?
  phoneNumberVerified Boolean?         @default(false)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @default(now())
  addresses           Address[]
  cartItems           CartItem[]
  orders              Order[]
  payments            Payment[]
  sessions            Session[]
  reviews             Review[]
  wishlists           Wishlist[]
  Authenticator       Authenticator[]
  accounts            Account[]
  recentlyVieweds     RecentlyViewed[]
  blogPosts           BlogPost[]
  blogComments        BlogComment[]

  phone_number String?

  @@map("user")

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("wishlist")

model RecentlyViewed {
  id        String   @id @default(cuid())
  userId    String?
  sessionId String?
  productId String
  viewedAt  DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  session   Session? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
  @@index([productId])
  @@index([viewedAt])
  @@index([userId, viewedAt])
  @@index([sessionId, viewedAt])
  @@map("recently_viewed")

model SiteSettings {
  id                       String   @id @default(cuid())
  siteTitleEn              String?  @db.VarChar(255)
  siteTitleFa              String?  @db.VarChar(255)
  phoneEn                  String?  @db.VarChar(50)
  phoneFa                  String?  @db.VarChar(50)
  descriptionEn            String?  @db.Text
  descriptionFa            String?  @db.Text
  languageMode             String   @default("multilingual") @db.VarChar(20)
  defaultLanguage          String   @default("fa") @db.VarChar(5)
  enableProductSuggestions Boolean  @default(true)
  suggestionAlgorithm      String   @default("hybrid") @db.VarChar(20)
  maxSuggestions           Int      @default(6)
  primaryColorLight        String   @default("#3b82f6") @db.VarChar(7)
  secondaryColorLight      String   @default("#78716c") @db.VarChar(7)
  accentColorLight         String   @default("#10b981") @db.VarChar(7)
  backgroundColorLight     String   @default("#ffffff") @db.VarChar(7)
  foregroundColorLight     String   @default("#171717") @db.VarChar(7)
  primaryColorDark         String   @default("#60a5fa") @db.VarChar(7)
  secondaryColorDark       String   @default("#a8a29e") @db.VarChar(7)
  accentColorDark          String   @default("#10b981") @db.VarChar(7)
  backgroundColorDark      String   @default("#0a0a0a") @db.VarChar(7)
  foregroundColorDark      String   @default("#fafafa") @db.VarChar(7)
  defaultSeoTitle          String?  @db.VarChar(255)
  defaultSeoDescription    String?  @db.Text
  defaultOgImage           String?
  googleAnalyticsId        String?  @db.VarChar(50)
  maintenanceMode          Boolean  @default(false)
  allowRegistration        Boolean  @default(true)
  defaultCurrency          String   @default("USD") @db.VarChar(10)
  lowStockThreshold        Int      @default(10)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@map("site_settings")

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")

model BlogCategory {
  id          String     @id @default(cuid())
  name        String     @db.VarChar(100)
  slug        String     @unique @db.VarChar(100)
  description String?    @db.Text
  color       String?    @db.VarChar(7)
  icon        String?    @db.VarChar(50)
  order       Int        @default(0)
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  posts       BlogPost[]

  @@index([slug])
  @@index([order])
  @@index([active])
  @@map("blog_category")

model BlogTag {
  id        String         @id @default(cuid())
  name      String         @unique @db.VarChar(50)
  slug      String         @unique @db.VarChar(50)
  color     String?        @db.VarChar(7)
  createdAt DateTime       @default(now())
  posts     BlogPostTag[]

  @@index([slug])
  @@map("blog_tag")

model BlogPost {
  id            String         @id @default(cuid())
  title         String         @db.VarChar(255)
  slug          String         @unique @db.VarChar(255)
  excerpt       String?        @db.Text
  content       String         @db.Text
  featuredImage String?
  status        String         @default("draft") @db.VarChar(20)
  publishedAt   DateTime?
  authorId      String
  categoryId    String
  seoTitle      String?        @db.VarChar(255)
  seoDescription String?       @db.Text
  seoKeywords   String?        @db.Text
  ogImage       String?
  canonicalUrl  String?
  readingTime   Int?           @default(0)
  viewCount     Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  author        User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category      BlogCategory   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  tags          BlogPostTag[]
  comments      BlogComment[]

  @@index([slug])
  @@index([status])
  @@index([publishedAt])
  @@index([authorId])
  @@index([categoryId])
  @@index([status, publishedAt])
  @@index([authorId, status])
  @@index([categoryId, status])
  @@map("blog_post")

model BlogPostTag {
  id     String   @id @default(cuid())
  postId String
  tagId  String
  post   BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([postId, tagId])
  @@index([postId])
  @@index([tagId])
  @@map("blog_post_tag")

model BlogComment {
  id        String     @id @default(cuid())
  content   String     @db.Text
  authorId  String
  postId    String
  parentId  String?
  status    String     @default("pending") @db.VarChar(20)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post      BlogPost   @relation(fields: [postId], references: [id], onDelete: Cascade)
  replies   BlogComment[] @relation("BlogCommentReplies")
  parent    BlogComment?  @relation("BlogCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([authorId])
  @@index([parentId])
  @@index([status])
  @@index([postId, status])
  @@map("blog_comment")

model Collection {
  id          String            @id @default(cuid())
  name        String            @db.VarChar(255)
  slug        String            @unique @db.VarChar(255)
  description String?           @db.Text
  image       String?
  isActive    Boolean           @default(true)
  isFeatured  Boolean           @default(false)
  sortOrder   Int               @default(0)
  seoTitle    String?           @db.VarChar(255)
  seoDescription String?        @db.Text
  seoKeywords String?           @db.Text
  ogImage     String?
  canonicalUrl String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  products    CollectionProduct[]

  @@index([slug])
  @@index([isActive])
  @@index([isFeatured])
  @@index([sortOrder])
  @@index([isActive, sortOrder])
  @@index([isFeatured, sortOrder])
  @@map("collection")

model CollectionProduct {
  id           String    @id @default(cuid())
  collectionId String
  productId    String
  displayOrder Int       @default(0)
  createdAt    DateTime  @default(now())
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product      Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([collectionId, productId])
  @@index([collectionId])
  @@index([productId])
  @@index([collectionId, displayOrder])
  @@map("collection_product")
