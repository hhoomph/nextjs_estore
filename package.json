{
  "name": "nextjs_estore",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --inspect",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "test": "bun vitest run",
    "test:coverage": "bun vitest run --coverage",
    "test:watch": "bun vitest",
    "test:ui": "bun vitest --ui",
    "test:unit": "bun vitest run --config vitest.config.ts",
    "test:unit:watch": "bun vitest --config vitest.config.ts",
    "test:component": "vitest run --config vitest.component.config.ts",
    "test:component:watch": "vitest --config vitest.component.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "bun run test:unit && bun run test:component && bun run test:e2e",
    "test:performance": "bun run scripts/performance-test.js http://localhost:3000 http://localhost:3000/products http://localhost:3000/auth/signin http://localhost:3000/dashboard",
    "test:accessibility": "bun run scripts/accessibility-test.js http://localhost:3000 http://localhost:3000/products http://localhost:3000/auth/signin http://localhost:3000/dashboard",
    "test:core-web-vitals": "bun run scripts/core-web-vitals.js http://localhost:3000 http://localhost:3000/products http://localhost:3000/auth/signin http://localhost:3000/dashboard",
    "lighthouse": "lighthouse http://localhost:3000 --output=json --output-path=./reports/lighthouse/report.json",
    "lighthouse:ci": "lhci autorun",
    "db:test": "bun run scripts/test-database.ts",
    "db:seed": "bun run scripts/seed.ts",
    "db:studio": "prisma studio",
    "cache:clear": "bun run scripts/clear-turbopack-cache.ts",
    "perf:test": "node scripts/performance-test.js",
    "load:test": "node scripts/load-test.js",
    "load:test:custom": "node scripts/load-test.js --users 20 --duration 60 --rampup 10",
    "a11y:test": "node scripts/accessibility-test.js",
    "api:test": "vitest run tests/api-routes.test.ts",
    "db:test:integration": "vitest run tests/database-integration.test.ts",
    "e2e:enhanced": "playwright test tests/e2e/enhanced-user-journeys.spec.ts",
    "qa:test": "bun run scripts/test-quality-assurance.js",
    "test:auth": "bun run scripts/test-auth.ts",
    "test:translations": "vitest run --config vitest.api.config.ts tests/translations.test.ts",
    "create:admin": "bun run scripts/create-admin.ts",
    "staging:verify": "bun run scripts/staging-verification.js",
    "docs:add-jsdoc": "bun run scripts/add-jsdoc-comments.ts",
    "analyze:bundle": "bun run scripts/analyze-bundle.js",
    "analyze:bundle:cart": "bun run scripts/analyze-bundle.js --filter=cart",
    "optimize:bundle": "bun run scripts/analyze-bundle.js && echo 'Bundle analysis complete. Check bundle-analysis/ for detailed report.'",
    "analyze:bundle:ci": "bun run scripts/bundle-analysis-ci.js run",
    "analyze:bundle:ci:github": "bun run scripts/bundle-analysis-ci.js setup-github",
    "analyze:bundle:ci:jenkins": "bun run scripts/bundle-analysis-ci.js setup-jenkins",
    "analyze:bundle:ci:gitlab": "bun run scripts/bundle-analysis-ci.js setup-gitlab",
    "build-apk": "./build-apk.sh"
  },
